-- Query para consultar inconsistencias na integracao de clientes
SELECT ife.dta_criacao,
    ife.erros,
    ife.registro->>'codCliente' AS cod_cliente,
    ife.registro->>'nome' AS nom_cliente,
    ife.registro->>'cnpj' AS cnpj,
    CAST(ife.registro->>'ativoInativo' AS BOOLEAN) AS ativo_inativo,
    ife.registro->>'descricaoContato' AS contato_cliente,
    ife.registro->>'emailContato' AS email_contato_cliente,
    ife.registro->>'telefoneContato' AS telefone_contato_cliente,
    CAST(ife.registro->>'pagador' AS BOOLEAN) AS sap_pagador,
    ife.registro->>'codCustomerGroup' AS cod_customer_group,
    ife.registro->>'customerGroup' AS customer_group,
    ife.registro->>'codCanal' AS cod_canal,
    ife.registro->>'canal' AS canal,
    ife.registro->>'subCanal' AS sub_canal,
    ife.registro->>'codRegional' AS cod_regional,
    ife.registro->>'divisaoRegional' AS regional
FROM integracao_fila_erros ife
WHERE ife.tipo = 'CLIENTE'
    AND ife.dta_alteracao >= '2025-06-01 00:00:00'
    AND NOT EXISTS (
        SELECT 1
        FROM cliente c
            INNER JOIN cliente_contato cc ON c.id_contato_responsavel = cc.id
        WHERE c.id_externo = ife.registro->>'codCliente'
            AND c.nom_cliente = ife.registro->>'nome'
            AND c.des_cnpj = ife.registro->>'cnpj'
            AND c.ind_ativo = CAST(ife.registro->>'ativoInativo' AS BOOLEAN)
            AND cc.nom_contato = ife.registro->>'descricaoContato'
            AND cc.vlr_email = ife.registro->>'emailContato'
            AND cc.vlr_telefone = ife.registro->>'telefoneContato'
            AND c.ind_pagador = CAST(ife.registro->>'pagador' AS BOOLEAN)
    )
GROUP BY ife.dta_criacao,
    ife.erros,
    ife.registro->>'codCliente',
    ife.registro->>'nome',
    ife.registro->>'cnpj',
    CAST(ife.registro->>'ativoInativo' AS BOOLEAN),
    ife.registro->>'descricaoContato',
    ife.registro->>'emailContato',
    ife.registro->>'telefoneContato',
    CAST(ife.registro->>'pagador' AS BOOLEAN),
    ife.registro->>'codCustomerGroup',
    ife.registro->>'customerGroup',
    ife.registro->>'codCanal',
    ife.registro->>'canal',
    ife.registro->>'subCanal',
    ife.registro->>'codRegional',
    ife.registro->>'divisaoRegional'
ORDER BY ife.dta_criacao DESC;
