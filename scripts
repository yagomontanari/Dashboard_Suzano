-- Query para localizar os or�amentos do m�s relacionado ao fechamento, pegar o id e utilizar na query para buscar as ZAJUS
select o.id,
    o.descricao,
    afp.descricao as periodo,
    otv.nome as tipo_verba,
    o.status,
    o.vlr_orcamento,
    o.dta_criacao,
    o.dta_alteracao,
    u1.nom_usuario as id_usuario_criacao,
    u2.nom_usuario as id_usuario_alteracao
from orcamento o
    inner join usuario u1 on u1.id_externo = o.id_usuario_criacao
    inner join usuario u2 on u2.id_externo = o.id_usuario_alteracao
    inner join orcamento_tipo_verba otv on otv.id = o.id_tipo_verba
    inner join orcamento_linha_investimento oli on oli.id_orcamento = o.id
    inner join orcamento_desdobramento od on od.id_linha_investimento = oli.id
    inner join ano_fiscal_periodo afp on afp.id = od.id_periodo_orcamentario
where o.status in ('APROVADO', 'AGUARDANDO_APROVACAO')
group by o.id,
    o.descricao,
    afp.descricao,
    otv.nome,
    o.status,
    o.vlr_orcamento,
    o.dta_criacao,
    o.dta_alteracao,
    u1.nom_usuario,
    u2.nom_usuario
order by o.id desc;
-- Query para consultar erros de integracao de Provisão VK11
with dados as (
    select soi.id_orcamento,
        o.descricao,
        soi.tipo_integracao,
        soi.id_ajuste_verba,
        soi.status
    from suzano_orcamento_integracao soi
        inner join orcamento o on o.id = soi.id_orcamento
    where valid_from >= '2024-01-01'
    order by soi.id desc
)
select dados.id_orcamento,
    dados.descricao,
    dados.tipo_integracao,
    dados.id_ajuste_verba,
    count(1) filter (
        where dados.status = 'INTEGRADO'
    ) as integrado,
    count(1) filter (
        where dados.status = 'PENDENTE_INTEGRACAO'
    ) as pendente_integracao,
    count(1) filter (
        where dados.status = 'ERRO'
    ) as erro -- count(1) filter (where dados.status = 'PENDENTE_INTEGRACAO_1')
from dados
group by dados.id_orcamento,
    dados.descricao,
    dados.tipo_integracao,
    dados.id_ajuste_verba
order by dados.id_orcamento desc;
-- Query para acompanhar integração de ZAJU
with dados as (
    select sapmc.id_orcamento,
        otv.descricao as tipo_verba,
        o.descricao,
        sapmc.id_ajuste_verba,
        oav.tipo_ajuste,
        oav.dta_alteracao,
        sapmc.status,
        sapmc.purch_no_c
    from suzano_ajuste_provisao_memoria_calculo sapmc
        inner join orcamento o on sapmc.id_orcamento = o.id
        left join orcamento_ajuste_verba oav on sapmc.id_ajuste_verba = oav.id
        inner join orcamento_tipo_verba otv on o.id_tipo_verba = otv.id
    where sapmc.cond_value != 0
        and sapmc.dta_alteracao between '2025-10-01 00:00:00' and '2025-10-31 23:59:59' --and sapmc.dta_criacao >= '2024-01-01 00:00:00'
        and sapmc.status not in (
            'PENDENTE_INTEGRACAO1',
            'STATUS_INVALIDO',
            'INVALIDO'
        ) --and purch_no_c not in ('ZAJU_APUR_REPROVADA','ZAJU_AJUSTE_PGTO')
        --and sapmc.id_orcamento in (337,336,334,333)
        and sapmc.purch_no_c is not null
    order by sapmc.id desc
)
select dados.id_orcamento,
    dados.tipo_verba,
    dados.descricao,
    dados.id_ajuste_verba,
    dados.tipo_ajuste,
    dados.dta_alteracao,
    dados.purch_no_c,
    count(1) filter (
        where dados.status = 'INTEGRADO'
    ) as INTEGRADO,
    count(1) filter (
        where dados.status = 'PENDENTE_INTEGRACAO'
    ) as PENDENTE_INTEGRACAO,
    count(1) filter (
        where dados.status = 'ERRO'
    ) as ERRO,
    count(1) filter (
        where dados.status = 'PENDENTE_RETORNO'
    ) as PENDENTE_RETORNO,
    count(
        dados.status in ('INTEGRADO', 'PENDENTE_INTEGRACAO')
    ) as total_zaju
from dados
group by dados.id_orcamento,
    dados.tipo_verba,
    dados.descricao,
    dados.id_ajuste_verba,
    dados.tipo_ajuste,
    dados.dta_alteracao,
    dados.purch_no_c
order by dados.purch_no_c asc;
-- Query para consultar erros de ZAJU
select concat(sapmc.id, ','),
    sapmc.id,
    sapmc.id_orcamento,
    o.descricao as orcamento,
    oli.descricao as linha_investimento,
    oti.nome as tipo_linha_investimento,
    c.id_externo as cod_cliente,
    c.nom_cliente,
    sapmc.nro_nota_fiscal,
    s.nro_nota_fiscal,
    s.vkorg,
    s.nro_documento,
    s.valor_total,
    s.valor_liquido,
    sapmc.cond_value,
    sapmc.dta_criacao,
    sapmc.purch_no_c,
    sapmc.doc_type,
    sapmc.sequencial,
    sapmc.material,
    p.nom_produto,
    um.sigla,
    sapmc.cond_type,
    sapmc.status,
    sapmc.numov,
    sapmc.numfat,
    sapmc.dta_integracao,
    sapmc.msg
from suzano_ajuste_provisao_memoria_calculo sapmc
    inner join orcamento o on sapmc.id_orcamento = o.id
    inner join orcamento_linha_investimento oli on sapmc.id_linha_investimento = oli.id
    inner join orcamento_tipo_investimento oti on oli.id_tipo_investimento = oti.id
    inner join sellin s on sapmc.id_sellin = s.id
    inner join cliente c on s.id_cliente = c.id
    inner join produto p on sapmc.material = p.id_externo
    inner join unidade_medida um on p.id_unidade_medida = um.id
where sapmc.cond_value != 0
    and sapmc.dta_alteracao between '2025-09-01 00:00:00' and '2025-09-30 23:59:59'
    and sapmc.status in ('ERRO') --and purch_no_c in ('ZAJU_AJUSTE_VERBA_NOMI') --and sapmc.nro_nota_fiscal = '000000-1' order by c.id_externo asc;
    -- Query para acompanhamento dos pagamentos
    WITH dados AS (
        SELECT spi.id_pagamento,
            c.id_externo,
            c.nom_cliente,
            pa.vlr_final,
            spi.status,
            spi.ind_enviado_integracao
        FROM suzano_pagamento_integracao spi
            INNER JOIN cliente c ON spi.id_cliente = c.id
            INNER JOIN pagamento_acao pa ON spi.id_pagamento = pa.id
        WHERE spi.dta_alteracao >= '2025-02-01 00:00:00'
        ORDER BY spi.id DESC
    )
SELECT dados.id_externo AS id_cliente,
    dados.nom_cliente,
    COUNT(1) FILTER (
        WHERE dados.status = 'INTEGRADO'
    ) AS integrado,
    COUNT(1) FILTER (
        WHERE dados.status = 'PENDENTE_INTEGRACAO'
    ) AS pendente_integracao,
    COUNT(1) FILTER (
        WHERE dados.status = 'PENDENTE_RETORNO'
    ) AS pendente_retorno,
    COUNT(1) FILTER (
        WHERE dados.status = 'ERRO'
    ) AS erro,
    COUNT(1) FILTER (
        WHERE dados.status IN ('INTEGRADO', 'PENDENTE_INTEGRACAO', 'ERRO')
    ) AS total_pagamentos,
    SUM(
        CAST(
            REPLACE(dados.vlr_final::TEXT, ',', '.') AS NUMERIC(10, 2)
        )
    ) FILTER (
        WHERE dados.status = 'INTEGRADO'
    ) AS valor_pagamento,
    SUM(
        CAST(
            REPLACE(dados.vlr_final::TEXT, ',', '.') AS NUMERIC(10, 2)
        )
    ) FILTER (
        WHERE dados.status = 'ERRO'
            and dados.vlr_final IS NOT NULL
    ) AS valor_pagamento_erro
FROM dados
GROUP BY dados.id_externo,
    dados.nom_cliente;
