    ife.registro->>'valorBruto' as valor_total,
    ife.registro->>'valorLiquido' as valor_liquido,
    ife.registro->>'dataVencimentoLiq' as dta_venc_liq,
    ife.registro->>'tipoDocFat' as tipo_doc_fat,
    ife.registro->>'referenciaFat' as referencia_fat
from integracao_fila_erros ife
where tipo = 'SELLIN'
    and ife.dta_alteracao between '2026-01-01 00:00:00' and '2026-01-31 23:59:59' --and ife.registro ->>'produtoId' like '%90005082%'
    and not exists (
        select distinct se.nro_documento,
            se.id_produto,
            se.id_cliente,
            se.tipo_doc_fat
        from sellin se
        where se.nro_documento = cast(ife.registro->>'numeroDocFiscal' as integer) --and se.nro_nota_fiscal = ife.registro ->> 'numeroNF'
            and se.id_produto in (
                select p.id
                from produto p
                where p.id_externo = ife.registro->>'produtoId'
            )
            and se.id_cliente in (
                select c.id
                from cliente c
                where c.id_externo = ife.registro->>'clienteId'
            )
            and se.tipo_doc_fat = ife.registro->>'tipoDocFat'
    ) --and se.referencia_fat = ife.registro ->> 'referenciaFat')
group by ife.erros,
    ife.lote,
    ife.dta_criacao,
    ife.registro->>'dataEmissao',
    ife.registro->>'numeroNF',
    ife.registro->>'clienteId',
    ife.registro->>'nomCliente',
    ife.registro->>'numeroDocFiscal',
    ife.registro->>'itemDocumento',
    ife.registro->>'produtoId',
    ife.registro->>'nomProduto',
    ife.registro->>'unidadeMedida',
    ife.registro->>'quantidade',
    ife.registro->>'valorBruto',
    ife.registro->>'valorLiquido',
    ife.registro->>'dataVencimentoLiq',
    ife.registro->>'tipoDocFat',
