# --- TRADELINKS DASHBOARD - CONFIGURATION TEMPLATE ---
# Use este arquivo como base para configurar seus ambientes (Produção e Staging)

# 1. Banco de Métricas Suzano (Somente Leitura)
# Este banco geralmente é compartilhado entre os ambientes, mas pode ser diferente se houver um banco de homologação.
METRICS_DATABASE_URL=postgresql+asyncpg://USUARIO:SENHA@HOST:PORTA/NOME_BANCO

# 2. Banco de Aplicação/Usuários (Supabase)
# IMPORTANTE: Crie um projeto separado no Supabase para o ambiente de STAGING.
# O sistema suporta o prefixo STAGING_ para facilitar a configuração no Vercel (Ambiente Preview).
# Produção: SUPABASE_DATABASE_URL=...
# Staging: STAGING_SUPABASE_DATABASE_URL=... (O código converterá para SUPABASE_DATABASE_URL automaticamente)
SUPABASE_DATABASE_URL=postgresql+asyncpg://postgres.PROJECT_ID...

# 3. URLs do Frontend
# Produção: https://dashboard-suzano.vercel.app
# Staging: https://staging-dashboard-suzano.vercel.app
FRONTEND_URL=http://localhost:5173

# 4. CORS - Origens Permitidas
# Lista separada por vírgula de domínios permitidos.
# Exemplo: http://localhost:5173,https://staging-dashboard-suzano.vercel.app
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3001,https://dashboard-suzano.vercel.app,https://staging-dashboard-suzano.vercel.app

# 5. Segurança
# Gere uma chave aleatória e segura para cada ambiente.
SECRET_KEY=suzanodashboardsecretkey

# 6. Configurações de E-mail (SMTP GMAIL)
SMTP_USER=yago.montanari@gmail.com
SMTP_PASSWORD=SUA_SENHA_DE_APP_GMAIL
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
EMAILS_FROM_NAME="Portal Suzano Dashboard"
EMAILS_FROM_EMAIL=yago.montanari@gmail.com
